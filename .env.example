# Required: Bearer token to protect the push API
API_TOKEN=your-secret-token

# Optional: enable OpenAI chat (omit to run in receive-only mode)
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Optional: image generation model (default: dall-e-3)
# IMAGE_MODEL=dall-e-3

# Optional: system prompt for the AI agent
# SYSTEM_PROMPT=You are a helpful assistant.

# Optional: HTTP server port (default: 3000)
# HTTP_PORT=3000
